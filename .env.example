# Supabase Dashboard > Project Settings > API bölümünden alınır.

# Tarayıcıya açık (public) - Project URL
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Tarayıcıya açık (public) - anon/public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GİZLİ - sadece sunucuda kullanılır, ASLA tarayıcıya/GitHub'a göndermeyin.
# Project Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
